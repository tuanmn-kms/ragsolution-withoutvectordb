# RAG API Configuration
# Copy this file to .env and update with your values

# Main ask endpoint - used for asking questions
VITE_RAG_API_URL=https://localhost:7256/api/rag/ask

# Ingest endpoint - used for adding documents
# If not set, will be derived from VITE_RAG_API_URL
VITE_RAG_INGEST_API_URL=https://localhost:7256/api/rag/ingest

# Alternative endpoints you can use:
# /api/rag/ask       - Primary endpoint (AI-powered)
# /api/rag/question  - Alias for ask
# /api/rag/answer    - Alias for ask
